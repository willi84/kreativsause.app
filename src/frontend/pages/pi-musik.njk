] %}

<section class="pi-soundboard" aria-labelledby="pi-soundboard-title">
    <div class="pi-soundboard__hero">
        <p class="pi-soundboard__eyebrow">Erstes Beispiel</p>
        <h1 id="pi-soundboard-title">Glockenklang, Musik und Tanz mit Pi (3,14159)</h1>
        <p class="pi-soundboard__intro">
            Wähle den Button zur Zahl.
        </p>
    </div>

    <div class="pi-soundboard__grid" data-pi-soundboard>
        {% for track in soundboardTracks %}
            <article
                class="pi-track"
                data-pi-track="{{ track.id }}"
                data-pi-sample="{{ track.sample }}"
                style="--pi-track-color: {{ track.color }};">
                <button
                    class="pi-track__button"
                    type="button"
                    data-pi-track-button
                    aria-label="Klangstück {{ track.id }} abspielen oder stoppen">
                    <span class="pi-track__number">{{ track.id }}</span>
                </button>
                {# <div class="pi-track__meta">
                    <span class="pi-track__source" data-pi-track-source>Internet</span>
                    <label class="pi-track__upload" for="pi-track-upload-{{ track.id }}">Audio wählen</label>
                    <input
                        class="pi-track__input"
                        id="pi-track-upload-{{ track.id }}"
                        type="file"
                        accept="audio/*"
                        data-pi-track-upload>
                </div> #}
            </article>
        {% endfor %}
    </div>
</section>
