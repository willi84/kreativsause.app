{% set soundboardTracks = [
  { id: 1, color: '#d8572a', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3' },
  { id: 2, color: '#4f6d7a', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3' },
  { id: 3, color: '#3c8d2f', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-3.mp3' },
  { id: 4, color: '#7b5ea7', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3' },
  { id: 5, color: '#c44569', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-5.mp3' },
  { id: 6, color: '#0081a7', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-6.mp3' },
  { id: 7, color: '#f4a261', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-7.mp3' },
  { id: 8, color: '#2a9d8f', sample: 'https://www.soundhelix.com/examples/mp3/SoundHelix-Song-8.mp3' }
] %}

<main class="grid">
  {% for track in soundboardTracks %}
    <button data-sound="{{ track.sample }}" class="btn" style="background-color: {{ track.color }};">{{ track.id }}</button>
  {% endfor %}
  </main>
<style>
html,
body {
  margin: 0;
  height: 100%;
  overflow: hidden;
}

.grid {
  width: 100vw;
  height: 100dvh;

  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  grid-template-rows: repeat(4, minmax(0, 1fr));
}

.btn {
  min-width: 0;
  min-height: 0;
  width: 100%;
  height: 100%;

  display: flex;
  align-items: center;
  justify-content: center;

  border: 0;
  overflow: hidden;

  font-size: clamp(3rem, 18vmin, 12rem);
  font-weight: 900;
  line-height: 1;
}
.active-sound{
  opacity: 1;
}

.active .btn{
  opacity: 0.5;
}
.active .btn.active-sound{
  opacity: 1;
}
@media (orientation: landscape) {
  .grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
  }
}
</style>
<script>
 const activeSoundClass = 'active-sound';
const activeClass = 'active';

const buttons = document.querySelectorAll('.btn[data-sound]');
const grid = document.querySelector('.grid');

let currentAudio = null;
let currentButton = null;

buttons.forEach(button => {
  button.addEventListener('click', () => {

    // gleicher Button -> stoppen
    if (button === currentButton) {
      currentAudio?.pause();
      currentAudio.currentTime = 0;

      button.classList.remove(activeSoundClass);
      grid.classList.remove(activeClass);

      currentAudio = null;
      currentButton = null;
      return;
    }

    // vorherigen stoppen
    currentAudio?.pause();
    if (currentAudio) currentAudio.currentTime = 0;

    buttons.forEach(b => b.classList.remove(activeSoundClass));

    // neuen starten
    button.classList.add(activeSoundClass);
    grid.classList.add(activeClass);

    currentAudio = new Audio(button.dataset.sound);
    currentAudio.play();

    currentButton = button;

    currentAudio.onended = () => {
      button.classList.remove(activeSoundClass);
      grid.classList.remove(activeClass);
      currentAudio = null;
      currentButton = null;
    };
  });
});
  </script>