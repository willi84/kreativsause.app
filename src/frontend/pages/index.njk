---
layout: base.template.njk
title: Welcome to kreativsause.app
navigation: true
footer: true
menu:
  label: Start
  emoji: 🏠
  order: 10
---

{%- from "./../templates/_setup/macros/component.macro.njk" import component -%}


{% set DATA = workshops %}
{% set items = workshops.workshops %}

{% set categories = workshops.meta.tags | getKeys | default([]) %}
{# {% set categories = ['montag', 'dienstag', 'mittwoch', 'donnerstag', 'freitag', 'samstag', 'sonntag'] %} #}
{# {% set categories = all.categories | default(['workshops']) %} #}
{% set statusClasses = all.configuration.status | default({}) %}
{% set eventCategories = ['hackathons', 'conferences', 'workshops'] %}
{% set categoryLabels = {
  montag: '💛 Montag',
  dienstag: '💚 Dienstag',
  mittwoch: '💙 Mittwoch',
  donnerstag: '🧡 Donnerstag',
  freitag: '🤍 Freitag',
  samstag: '❤️ Samstag',
  sonntag: '💜 Sonntag'
} 
%}


<section class="portfolio-shell" data-portfolio data-view="cards" data-theme="dark">
    <div class="container py-4 py-lg-5">
        <div class="craft-app-status-bar mb-3" data-app-status-bar>
            <div class="craft-app-status-list" aria-label="App Status">
                <span class="craft-app-status-pill" data-network-status data-state="unknown">
                    <span class="craft-app-status-icon" aria-hidden="true">●</span>
                    <span class="craft-app-status-text">Netz</span>
                </span>
                <span class="craft-app-status-pill" data-cache-status data-state="unknown">
                    <span class="craft-app-status-icon" aria-hidden="true">✓</span>
                    <span class="craft-app-status-text">Cache</span>
                </span>
                <span class="craft-app-status-pill" data-runtime-status data-state="unknown">
                    <span class="craft-app-status-icon" aria-hidden="true">↻</span>
                    <span class="craft-app-status-text">Quelle</span>
                </span>
                <span class="craft-app-status-pill" data-install-status data-state="unknown">
                    <span class="craft-app-status-icon" aria-hidden="true">⬇</span>
                    <span class="craft-app-status-text">App</span>
                </span>
            </div>
            <div class="craft-app-status-actions">
                <button
                    class="btn btn-sm craft-app-install d-none"
                    type="button"
                    data-pwa-install
                    aria-label="App installieren">
                    ⬇ App installieren
                </button>
            </div>
        </div>
        {{
            component("menu", {
                page: page,
                url: "/plan",
                main: main,
                title: "Kreativsause.app",
                subtitle: "Ein kleiner Helfer für die Kreativsause 2026",
                state: "in Arbeit",
                views: [{ key: 'cards', label: '▦ Cards'}, { key: 'list', label: '☰ Liste' }, { key: 'schedule', label: '🕒 Schedule' }]
            })
        }}
        <section search-context>
            
    <nav class="portfolio-toolbar mb-4  z-2 position-relative" aria-label="Portfolio Filter">
        <div class="row g-3 align-items-center">
            <div class="col-12 col-lg-8">
                {{
                    component("search", {
                        label: "Portfolio durchsuchen",
                        class: "portfolio-input",
                        placeholder: "grep: Titel, Ort, Status, Tags …"
                    })
                }}
            </div>
            <div class="col-12 col-lg-4 portfolio-actions mt-0">
                {{
                    component("dropdown", {
                        values: [ 'date-desc','date-asc', 'title-asc', 'title-desc', 'status-asc', 'status-desc'],
                        defaultValue: "date-desc",
                        key: "bs-sort",
                        label: "Sortierung",
                        sort: "[data-category-section]"
                    })
                }}
            </div>
            <div class="col-12 col-lg-12">
                <div class="portfolio-filter-scroll gap-2 justify-content-lg-end" data-category-filter>
                    {{
                        component("filter-button", {
                            key: "all",
                            label: "Alle",
                            css: 'mb-2',
                            length: items | length
                        })
                    }}
                    {% for category in categories %}
                        {{
                            component("filter-button", {
                                key: category,
                                label: categoryLabels[category] | default(category),
                                css: 'mb-2',
                                length: workshops.meta.tags[category],
                                config: workshops.meta.tags                          
                              })
                        }}
                    {% endfor %}
                </div>
            </div>
        </div>
    </nav>
    
    {% set days = ['montag', 'dienstag', 'mittwoch', 'donnerstag', 'freitag', 'samstag', 'sonntag'] %}
    {% for day in days %}
        <section class="portfolio-category mb-5" data-category-section="{{ day }}" data-schedule-day>
            <div class="portfolio-category-head mb-3">
                <h2 class="h4 mb-0">{{ categoryLabels[day] | default(day) }}</h2>
                <span class="portfolio-count"><span data-count>0</span> items</span>
            </div>
            <div class="portfolio-grid craft-cards-view">
                {% for key, item in items %}
                    {% if item.days | contains(day) %}
                        {% set statusClass = statusClasses[item.status] | default('text-bg-secondary') %}
                        {% set metaData = [
                            { key: "date", start: item.start, end: item.end },
                            { key: "project", value: item.project },
                            { key: "role", value: item.role },
                            { key: "conductor", value: item.conductor },
                            { key: "type", value: item.type }
                            ] 
                        %}
                        {% set css_link = "btn btn-sm portfolio-link" %}
                        {% set links = item.links | default([]) %}

                        {{ component("card", { item: item, category: day, meta: metaData, links: links, config: workshops.meta })}}
                    {% endif %}
                {% endfor %}
            </div>

            <div class="craft-schedule-view craft-inline-schedule">
                {% for key, item in items %}
                    {% if item.days | contains(day) %}
                        {% set speakerNames = item.speakers | join(', ') if item.speakers else item.title %}
                        {% set speakerImage = item.speaker_image if item.speaker_image else '/assets/unknown.svg' %}
                        {% set venueLabel = item.venue | join(' · ') if item.venue else '' %}
                        <details
                            class="craft-inline-schedule-item"
                            data-search-item
                            data-search-mirror="1"
                            data-schedule-item
                            data-talk-item
                            data-talk-id="{{ item.id }}"
                            data-talk-title="{{ item.title }}"
                                                                                                    data-stage-label="{{ item.venue[0] | default(item.title) }}"
                            data-stage-svg-ids=""
                            data-category="{{ item.tags }}"
                            data-search="{{ item | getSearchValue(day) }}"
                            data-start="{{ item.start }}"
                            data-end="{{ item.end }}"
                            data-canceled="{% if item.canceled %}1{% else %}0{% endif %}">
                            <summary class="craft-inline-schedule-summary">
                                <span class="craft-inline-schedule-topline">
                                    {% if venueLabel %}
                                        <span class="craft-venue craft-venue-inline">
                                            <span class="craft-venue-icon" aria-hidden="true">🏡</span>
                                            <span class="craft-venue-list">
                                                {% for venue in item.venue %}
                                                    <span class="craft-venue-name">{{ venue }}</span>{% if not loop.last %}<span class="craft-venue-separator" aria-hidden="true">·</span>{% endif %}
                                                {% endfor %}
                                            </span>
                                        </span>
                                    {% endif %}
                                    <span class="craft-inline-schedule-time">
                                        <strong>{{ item.start | formatDate('time') }}</strong>
                                        <small>{{ item.end | formatDate('time') }}</small>
                                    </span>
                                </span>
                                <span class="craft-inline-schedule-body">
                                    <span class="craft-inline-schedule-avatar" aria-hidden="true">
                                        <img
                                            src="{{ speakerImage }}"
                                            alt="Speaker photo of {{ speakerNames }}"
                                            width="56"
                                            height="56"
                                            loading="lazy">
                                    </span>
                                    <span class="craft-inline-schedule-copy">
                                        <span class="craft-inline-schedule-title" data-search-mark>{{ item.title }}</span>
                                        <span class="craft-inline-schedule-speaker" data-search-mark>{{ speakerNames }}</span>
                                    </span>
                                    {% if item.changes.length > 0 %}
                                        <span class="craft-inline-schedule-change-flag" title="Änderung vorhanden">⚠️</span>
                                    {% endif %}
                                    <span class="craft-inline-schedule-status" data-talk-status><span data-talk-status-label>Status</span></span>
                                </span>
                            </summary>

                            <div class="craft-inline-schedule-details">
                                <p class="craft-inline-schedule-meta">{{ item.start | formatDate('date') }} · {{ item.start | formatDate('time') }} - {{ item.end | formatDate('time') }}</p>
                                {% if item.changes.length > 0 %}
                                    <p class="portfolio-change-note" data-search-mark>
                                        <span aria-hidden="true">⚠️</span>
                                        <span>
                                            Änderung:
                                            {% for change in item.changes %}
                                                {% if change == 'cancelled' %}abgesagt{% endif %}
                                                {% if change == 'new' %}neu{% endif %}
                                                {% if change == 'changed location' %}Ort geändert{% endif %}
                                                {% if change == 'changed day' %}Tag geändert{% endif %}
                                                {% if change == 'changed time' %}Zeit geändert{% endif %}
                                                {% if loop.index < item.changes.length %}, {% endif %}
                                            {% endfor %}
                                        </span>
                                    </p>
                                {% endif %}
                                {% if venueLabel %}
                                    <p class="craft-inline-schedule-meta">
                                        <span class="craft-venue craft-venue-detail">
                                            <span class="craft-venue-icon" aria-hidden="true">🏡</span>
                                            <span class="craft-venue-list">
                                                {% for venue in item.venue %}
                                                    <span class="craft-venue-name">{{ venue }}</span>{% if not loop.last %}<span class="craft-venue-separator" aria-hidden="true">·</span>{% endif %}
                                                {% endfor %}
                                            </span>
                                        </span>
                                    </p>
                                {% endif %}
                                {% if item.description %}
                                    <div class="craft-inline-schedule-description">
                                        {% for description in item.description %}
                                            {% if loop.index < 3 %}
                                                <p class="portfolio-description" data-search-mark>{{ description }}</p>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <div class="portfolio-badges">
                                    {% for tag in item.tags %}
                                        {{ component("badge", { text: tag, css: "portfolio-muted-badge", config: workshops.meta.tags }) }}
                                    {% endfor %}
                                </div>
                                <div class="portfolio-links">
                                    <button
                                        class="btn btn-sm portfolio-link craft-plan-toggle"
                                        type="button"
                                        data-plan-toggle
                                        data-talk-id="{{ item.id }}"
                                        aria-pressed="false">
                                        💾 Merken
                                    </button>
                                    {% if item.register and item.register != '' %}
                                        {{ component("link", { url: item.register, text: '👉 register', css: 'btn btn-sm portfolio-link pd-1', target: '_blank' }) }}
                                    {% endif %}
                                </div>
                            </div>
                        </details>
                    {% endif %}
                {% endfor %}
            </div>
        </section>
    {% endfor %}

    <p class="portfolio-empty d-none" data-search-empty>Keine passenden Einträge gefunden.</p>
</section>
    </div>
</section>
